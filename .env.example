# Copy to .env and adjust for your local OpenAI-compatible server (e.g. LM Studio).
# Do not commit .env (see .gitignore).

LLM_BASE_URL=http://localhost:1234
# LLM_API_KEY=

# -----------------------------------------------------------------------------
# Profile A — small context (~13k), e.g. google/gemma-3-27b on tight VRAM
# -----------------------------------------------------------------------------
LLM_MODEL=google/gemma-3-27b
LLM_CONTEXT_TOKENS=13000
LLM_COMPLETION_TRANSLATE=4500
LLM_COMPLETION_EXTRACT=1800
LLM_COMPLETION_VALIDATE=3200
LLM_COMPLETION_TIMELINE=2500
# Metadata extraction (entity facts, relation edges, scenes) — separate from glossary extract
LLM_COMPLETION_FACTS=2300
LLM_COMPLETION_RELATIONS=2300
LLM_COMPLETION_SCENES=2300
GLOSSARY_INJECT_TOKENS=1200
GLOSSARY_MAX_ENTRIES=40
# Context budget helpers (translate_pipeline chunk sizing)
# LLM_SAFETY_TOKENS=400
# LLM_EXISTING_GLOSSARY_CAP_TOKENS=900
# Chapter title line (translate_title.txt) — raise for reasoning models
# LLM_COMPLETION_TRANSLATE_TITLE=512
# LLM_TITLE_GLOSSARY_INJECT_CAP=800
# LLM_TITLE_GLOSSARY_MAX_ENTRIES=20
# Row caps when building chapter glossary (min with GLOSSARY_MAX_ENTRIES)
# LLM_GLOSSARY_MERGE_MAX_ENTRIES=25
# LLM_GLOSSARY_TIMELINE_MAX_ENTRIES=40
# LLM_GLOSSARY_METADATA_MAX_ENTRIES=45
# Max ZH chars per metadata chunk (upper cap after context math)
# LLM_METADATA_FACTS_CHUNK_MAX_CHARS=6000
# LLM_METADATA_RELATIONS_CHUNK_MAX_CHARS=7000
# LLM_METADATA_SCENES_CHUNK_MAX_CHARS=7000
# Timeline body chunk cap (CLI: --timeline-max-chars)
# LLM_TIMELINE_MAX_CHARS=9000
LLM_TIMEOUT_S=120

# -----------------------------------------------------------------------------
# Profile B — large context (~100k), e.g. Qwen 3.5 35B uncensored
# Uncomment and tune to match your server's REAL context + VRAM.
# IMPORTANT: raising LLM_CONTEXT_TOKENS without raising LLM_COMPLETION_TRANSLATE
# can cause truncated Vietnamese output (chunk fits in prompt but reply is cut).
# LM Studio "reasoning" models may put a long chain-of-thought in reasoning_content
# before JSONL; if finish_reason is "length", raise LLM_COMPLETION_EXTRACT (e.g. 8000–12000).
# -----------------------------------------------------------------------------
# LLM_MODEL=qwen3.5-35b-a3b-uncensored-hauhaucs-aggressive
# LLM_CONTEXT_TOKENS=100000
# LLM_COMPLETION_TRANSLATE=10000
# LLM_COMPLETION_EXTRACT=4000
# LLM_COMPLETION_VALIDATE=6000
# LLM_COMPLETION_TIMELINE=4000
# LLM_COMPLETION_FACTS=4000
# LLM_COMPLETION_RELATIONS=4000
# LLM_COMPLETION_SCENES=4000
# Translate prompt (file name under prompts/ or path relative to project root)
# TRANSLATE_PROMPT_FILE=translate_qwen3.5-35b-a3b-uncensored-hauhaucs-aggressive.txt
# CJK line-fix retry prompt (JSONL output; only bad lines are sent to the model)
# CJK_RETRY_PROMPT_FILE=translate_retry_cjk_leak.txt
# Enable rule-based CJK leak fix after each translate chunk (translate stage only; not glossary/timeline)
# TRANSLATE_CJK_VALIDATE=1
# CJK_VALIDATE_RETRIES=3
# Short completion budget for CJK line-fix calls (separate from main translate chunk)
# LLM_COMPLETION_CJK_FIX=1536
# GLOSSARY_INJECT_TOKENS=2000
# GLOSSARY_MAX_ENTRIES=50
# LLM_TIMEOUT_S=300

LLM_MAX_RETRIES=3

# If 1: omit max_tokens from /v1/chat/completions (LM Studio / server uses its own default).
# max_tokens is a ceiling, not a "target length" — omitting does not make the model "freely decide";
# it may run longer, hit context limits, or error if the server requires max_tokens.
# LLM_OMIT_MAX_TOKENS=1

# Legacy translate validate (validate.txt): if it fails, retry full-chunk translate + validate again (4 LLM/chunk worst case).
# Set to 0 to keep first VI and rely on CJK line-fix or manual edit instead.
# VALIDATE_RETRY_WHOLE_CHUNK=0

# Title line: by default the pipeline translates "Chapter N - <ZH>…" in a separate step.
# Use: python translate_pipeline.py ... --no-translate-header   to keep Chinese title.
